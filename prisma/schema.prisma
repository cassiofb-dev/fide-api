// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Player {
  id                  Int           @id
  name                String
  federation          String?
  birthYear           Int?
  gender              String?
  title               String?
  stdRating           Int?
  rapidRating         Int?
  blitzRating         Int?
  worldRankActive     Int?
  worldRankAll        Int?
  nationalRankActive  Int?
  nationalRankAll     Int?
  continentRankActive Int?
  continentRankAll    Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  chart               PlayerChart?
  stats               PlayerStats?
}

model PlayerChart {
  playerId  Int      @id
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  data      String   // JSON string containing rating history points
  updatedAt DateTime @default(now()) @updatedAt
}

model PlayerStats {
  playerId          Int    @id
  player            Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  whiteTotal        Int
  whiteWinNum       Int
  whiteDrawNum      Int
  blackTotal        Int
  blackWinNum       Int
  blackDrawNum      Int
  whiteTotalStd     Int
  whiteWinNumStd    Int
  whiteDrawNumStd   Int
  blackTotalStd     Int
  blackWinNumStd    Int
  blackDrawNumStd   Int
  whiteTotalRpd     Int
  whiteWinNumRpd    Int
  whiteDrawNumRpd   Int
  blackTotalRpd     Int
  blackWinNumRpd    Int
  blackDrawNumRpd   Int
  whiteTotalBlz     Int
  whiteWinNumBlz    Int
  whiteDrawNumBlz   Int
  blackTotalBlz     Int
  blackWinNumBlz    Int
  blackDrawNumBlz   Int
  updatedAt         DateTime @default(now()) @updatedAt
}

model TopList {
  listType  String   @id // e.g. "open", "women", "juniors_rapid"
  data      String   // JSON string containing TopListPlayer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
